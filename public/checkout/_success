<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>Welcome — Lust Playhouse</title>
<style>
  :root {
    --bg: #0a0618;
    --card-bg: #0d0b1a;
    --purple: #a855f7;
    --purple-light: #d8b4fe;
    --purple-deep: #7c3aed;
    --pink: #ec4899;
    --text: #f5f3ff;
    --text-dim: #9c93b8;
    --border: rgba(168,85,247,0.2);
    --green: #4ade80;
  }
  * { box-sizing: border-box; }
  body {
    margin: 0;
    min-height: 100vh;
    background: #0a0618;
    background-image:
      radial-gradient(circle at 50% 0%, rgba(124,58,237,0.25) 0%, transparent 60%),
      radial-gradient(circle at 50% 100%, rgba(236,72,153,0.18) 0%, transparent 60%),
      linear-gradient(to bottom, #160b2e, #0a0618, #050410);
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
    color: var(--text);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 56px 20px;
  }
  .card {
    width: 100%;
    max-width: 420px;
    background: var(--card-bg);
    border: 1px solid var(--border);
    border-radius: 16px;
    padding: 40px 28px;
    text-align: center;
    box-shadow: 0 0 50px rgba(168,85,247,0.12);
  }
  .check {
    width: 56px;
    height: 56px;
    margin: 0 auto 20px;
    border-radius: 50%;
    background: rgba(74,222,128,0.12);
    border: 1px solid rgba(74,222,128,0.4);
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .check svg { width: 28px; height: 28px; }
  h1 {
    font-size: 22px;
    margin: 0 0 8px;
  }
  p.sub {
    color: var(--text-dim);
    font-size: 14px;
    margin: 0 0 28px;
    line-height: 1.5;
  }
  a.cta {
    display: block;
    width: 100%;
    padding: 16px;
    border-radius: 12px;
    font-size: 15px;
    font-weight: 700;
    color: #fff;
    text-decoration: none;
    background: linear-gradient(135deg, var(--purple), var(--pink));
    box-shadow: 0 8px 24px rgba(168,85,247,0.35);
  }
  p.footnote {
    margin-top: 18px;
    font-size: 12px;
    color: var(--text-dim);
  }
  .copyright {
    margin-top: 32px;
    font-size: 11px;
    color: var(--text-dim);
    opacity: 0.6;
  }
</style>
</head>
<body>
  <div class="card">
    <div class="check">
      <svg viewBox="0 0 24 24" fill="none" stroke="#4ade80" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
        <polyline points="20 6 9 17 4 12"></polyline>
      </svg>
    </div>
    <h1>You're in!</h1>
    <p class="sub">Thank you for joining the __TIER_NAME__ tier. Tap below to enter the private community — your access is lifetime, no renewals needed.</p>
    <a class="cta" href="__COMMUNITY_LINK__" target="_blank" rel="noopener">Join on Telegram</a>
    <p class="footnote">Save or screenshot this link now — it won't be re-sent automatically.</p>
  </div>
  <div class="copyright">(c) 2026 Lust Playhouse</div>
</body>
</html>
